{
  "name": "bikrikhata",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "node scripts/check-tailwind-classes.mjs",
    "lint:tailwind": "node scripts/check-tailwind-classes.mjs",
    "deploy:check": "npm run lint:tailwind && npm run build",
    "prepush": "npm run deploy:check && npm run e2e:smoke && npm run e2e:live && npm run e2e:matrix",
    "prepush:full": "npm run deploy:check && npm run e2e:full",
    "e2e:smoke": "node scripts/e2e-supabase-smoke.mjs",
    "e2e:live": "node scripts/e2e-supabase-live.mjs",
    "e2e:phase1": "node scripts/e2e-phase1-full.mjs",
    "e2e:matrix": "node scripts/e2e-phase1-matrix.mjs",
    "e2e:bill": "node --experimental-strip-types scripts/e2e-bill-print.mjs",
    "e2e:bill:live": "node --experimental-strip-types scripts/e2e-bill-print.mjs --live",
    "e2e:stock": "node scripts/e2e-stock-dates.mjs",
    "e2e:stock:live": "node scripts/e2e-stock-dates.mjs --live",
    "e2e:stock-bill": "npm run e2e:bill && npm run e2e:stock:live",
    "e2e:export": "node scripts/e2e-export.mjs",
    "e2e:tier-a": "node scripts/e2e-tier-a.mjs",
    "e2e:tier-a:live": "node scripts/e2e-tier-a.mjs --live",
    "e2e:tier-b": "node scripts/e2e-tier-b.mjs",
    "e2e:tier-b:live": "node scripts/e2e-tier-b.mjs --live",
    "e2e:tier-c": "node scripts/e2e-tier-c.mjs",
    "e2e:tier-c:live": "node scripts/e2e-tier-c.mjs --live",
    "e2e:p0-public": "node scripts/e2e-p0-public.mjs",
    "capture:marketing": "node scripts/capture-marketing-screenshots.mjs",
    "test:contact-form": "node scripts/test-contact-form.mjs",
    "test:contact-email": "node scripts/test-contact-email-health.mjs",
    "deploy:contact-email": "bash scripts/deploy-contact-email.sh",
    "setup:contact-email": "node scripts/setup-contact-email.mjs",
    "e2e:phase0": "node scripts/e2e-phase0.mjs",
    "e2e:phase0:live": "node scripts/e2e-phase0.mjs --live",
    "e2e:suppliers": "node scripts/e2e-supplier-invoices.mjs",
    "e2e:suppliers:live": "node scripts/e2e-supplier-invoices.mjs --live",
    "e2e:mrp": "node scripts/e2e-mrp-stickers.mjs",
    "e2e:mrp:live": "node scripts/e2e-mrp-stickers.mjs --live",
    "e2e:bill:ui": "node --experimental-strip-types scripts/e2e-bill-print.mjs --ui",
    "e2e:bill:full": "node --experimental-strip-types scripts/e2e-bill-print.mjs --live --ui",
    "e2e:bill:visual": "node scripts/e2e-bill-visual.mjs",
    "e2e:ui:setup": "playwright install chromium",
    "e2e:ui": "node scripts/ui-e2e-phase1.mjs",
    "e2e:all": "node scripts/e2e-phase1-matrix.mjs && node scripts/ui-e2e-phase1.mjs",
    "e2e:full": "node scripts/e2e-supabase-smoke.mjs && node scripts/e2e-supabase-live.mjs && node scripts/e2e-phase1-matrix.mjs && node scripts/ui-e2e-phase1.mjs",
    "seed:demo": "node scripts/tenant-seed.mjs seed",
    "seed:demo:reset": "node scripts/tenant-seed.mjs seed --reset",
    "seed:schemes": "node scripts/seed-schemes.mjs",
    "seed:purge": "node scripts/tenant-seed.mjs purge --yes",
    "tenant:reset-data": "node scripts/reset-tenant-data.mjs --yes",
    "e2e:seed:selftest": "node scripts/e2e-tenant-seed-selftest.mjs",
    "supabase:types": "supabase gen types typescript --linked > src/types/database.types.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/supabase-js": "^2.104.0",
    "@tanstack/react-query": "^5.99.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.8.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.73.1",
    "react-router-dom": "^6.30.3",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.58.0",
    "postcss": "^8.5.10",
    "supabase": "^2.93.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^1.2.0"
  }
}
